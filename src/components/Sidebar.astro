---
import { NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
	href === '/' ? path === '/' : path === href || path.startsWith(href);
const year = new Date().getFullYear();
---

<aside class="sidebar">
	<div class="top">
		<a class="brand" href="/">
			<span class="brand-name">Sool Park</span>
			<span class="brand-ko">박술<span class="sep">|</span>朴述</span>
		</a>
		<nav class="index">
			{
				NAV.map((item) =>
					item.children ? (
						<div class="group">
							<span class="nav-link group-label">
								<span class="arrow">→</span>
								<span>{item.label}</span>
							</span>
							<div class="sub">
								{item.children.map((c) => (
									<a href={c.href} class:list={['nav-link', 'sub-link', { active: isActive(c.href) }]}>
										<span class="arrow">→</span>
										<span>{c.label}</span>
									</a>
								))}
							</div>
						</div>
					) : (
						<a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
							<span class="arrow">→</span>
							<span>{item.label}</span>
						</a>
					),
				)
			}
		</nav>
		<div class="social">
			<a href="https://uni-hildesheim.academia.edu/SoolPark" target="_blank" rel="me noopener">Academia.edu ↗</a>
			<a href="https://www.instagram.com/parksool_/" target="_blank" rel="me noopener">Instagram ↗</a>
		</div>
	</div>
	<p class="colophon">© {year} Sool Park · <a href="/rss.xml">RSS</a></p>
</aside>
<style>
	.sidebar {
		position: sticky;
		top: 0;
		align-self: flex-start;
		width: var(--sidebar-w);
		min-width: var(--sidebar-w);
		height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 4.5rem 1.6rem 2rem 2.2rem;
	}
	.brand { display: block; text-decoration: none; line-height: 1.05; }
	.brand-name {
		display: block;
		font-size: 1.6rem;
		font-weight: 700;
		letter-spacing: normal;
		color: rgb(var(--black));
	}
	.brand-ko {
		display: block;
		font-size: 1.15rem;
		color: rgb(var(--black));
		font-weight: 700;
		margin-top: 0.55em;
	}
	.brand-ko .sep { color: rgb(var(--gray)); font-weight: 400; margin: 0 0.5em; }

	.index { display: flex; flex-direction: column; gap: 0.15em; margin-top: 2.4rem; }
	.nav-link {
		display: flex;
		gap: 0.5em;
		padding: 0.22em 0;
		font-size: 1.02rem;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: color 0.12s ease;
	}
	.nav-link .arrow { color: var(--accent); opacity: 0; transition: opacity 0.12s ease; }
	.nav-link:hover { color: var(--accent); }
	.nav-link:hover .arrow,
	.nav-link.active .arrow { opacity: 1; }
	.nav-link.active { color: var(--accent); font-weight: 700; }

	/* Work group — always expanded; the label is a non-clickable category header */
	.group { margin: 0; }
	.group-label { cursor: default; }
	.group-label:hover { color: rgb(var(--gray-dark)); }
	.group-label .arrow { opacity: 0 !important; }
	.sub { display: flex; flex-direction: column; gap: 0.05em; padding: 0.05em 0 0.4em 1.3em; }
	.sub-link { font-size: 0.96rem; }

	.social { margin-top: 1.8rem; }
	.social a { display: block; font-size: 0.92rem; color: rgb(var(--gray)); text-decoration: none; margin-bottom: 0.25em; }
	.social a:hover { color: var(--accent); }

	.colophon { font-size: 0.78rem; color: rgb(var(--gray)); margin: 2rem 0 0; }
	.colophon a { color: rgb(var(--gray)); }
	.colophon a:hover { color: var(--accent); }

	@media (max-width: 860px) {
		.sidebar {
			position: static;
			width: 100%;
			min-width: 0;
			height: auto;
			padding: 1.6rem 1.4rem 0.5rem;
		}
		.index { margin-top: 1.4rem; }
		.nav-link .arrow { display: none; }
		.social { margin-top: 1.2rem; }
		.colophon { display: none; }
	}
</style>
