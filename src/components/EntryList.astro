---
interface Item {
	href: string;
	title: string;
	eyebrow?: string;
	meta?: string;
	description?: string;
}
interface Props { items: Item[]; }
const { items } = Astro.props;
---

<ul class="entry-list">
	{
		items.map((it) => (
			<li>
				<a class="row" href={it.href}>
					<span class="arrow">→</span>
					<span class="body">
						{it.eyebrow && <span class="eyebrow">{it.eyebrow}</span>}
						<span class="title">{it.title}</span>
						{it.meta && <span class="meta">{it.meta}</span>}
						{it.description && <span class="desc">{it.description}</span>}
					</span>
				</a>
			</li>
		))
	}
</ul>
<style>
	.entry-list { list-style: none; margin: 0; padding: 0; }
	.entry-list li { margin: 0; }
	.row {
		display: flex;
		gap: 0.6em;
		padding: 0.95em 0;
		text-decoration: none;
		color: rgb(var(--black));
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.entry-list li:first-child .row { border-top: 1px solid rgb(var(--gray-light)); }
	.arrow { color: var(--accent); opacity: 0; transition: opacity 0.12s ease; line-height: 1.5; }
	.row:hover .arrow { opacity: 1; }
	.body { display: flex; flex-direction: column; min-width: 0; }
	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--accent);
		margin-bottom: 0.2em;
	}
	.title { font-size: 1.18rem; font-weight: 700; line-height: 1.3; }
	.row:hover .title { color: var(--accent); }
	.meta { color: rgb(var(--gray)); font-size: 0.85rem; margin-top: 0.2em; }
	.desc {
		color: rgb(var(--gray-dark));
		font-size: 0.92rem;
		margin-top: 0.35em;
		line-height: 1.5;
	}
</style>
