---
import { getCollection, render } from 'astro:content';
import Entry from '../../layouts/Entry.astro';

export async function getStaticPaths() {
	const items = await getCollection('aktuelles');
	return items.map((item) => ({ params: { slug: item.id }, props: item }));
}

const item = Astro.props;
const { Content } = await render(item);
---

<Entry
	title={item.data.title}
	description={item.data.description ?? item.data.title}
	date={item.data.datum ?? item.data.pubDate}
	meta={item.data.ort}
	eyebrow="News"
	backHref="/aktuelles/"
	backLabel="All news"
>
	<Content />
	{item.data.url && (
		<p><a href={item.data.url} target="_blank" rel="noopener">→ More information</a></p>
	)}
</Entry>
