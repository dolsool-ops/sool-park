---
import { getCollection, render } from 'astro:content';
import Entry from '../../layouts/Entry.astro';

export async function getStaticPaths() {
	const items = await getCollection('texte');
	return items.map((item) => ({ params: { slug: item.id }, props: item }));
}

const item = Astro.props;
const { Content } = await render(item);
---

<Entry
	title={item.data.title}
	description={item.data.description ?? item.data.title}
	date={item.data.pubDate}
	eyebrow={item.data.rubrik}
	backHref="/texte/"
	backLabel="All posts"
>
	<Content />
</Entry>
