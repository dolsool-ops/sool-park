---
import { getCollection, render } from 'astro:content';
import Entry from '../../layouts/Entry.astro';

export async function getStaticPaths() {
	const items = await getCollection('books');
	return items.map((item) => ({ params: { slug: item.id }, props: item }));
}

const item = Astro.props;
const { Content } = await render(item);
const meta = [item.data.verlag, item.data.jahr, item.data.status].filter(Boolean).join(' · ');
---

<Entry
	title={item.data.title}
	description={item.data.description ?? item.data.title}
	eyebrow={item.data.autor}
	meta={meta}
	backHref="/books/"
	backLabel="All books"
>
	<Content />
</Entry>
