---
import { getCollection } from 'astro:content';
import Section from '../../layouts/Section.astro';
import EntryList from '../../components/EntryList.astro';

const items = (await getCollection('interviews'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((i) => ({
		href: `/interviews/${i.id}/`,
		title: i.data.title,
		eyebrow: 'Interview',
		meta: [
			i.data.medium,
			i.data.interviewer,
			i.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long' }),
		]
			.filter(Boolean)
			.join(' · '),
		description: i.data.description,
	}));
---

<Section
	title="Interviews"
	description="Interviews and conversations with Sool Park."
	intro="Conversations and interviews on translation, philosophy and literature."
>
	<EntryList items={items} />
</Section>
