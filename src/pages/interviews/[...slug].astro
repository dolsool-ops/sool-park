---
import { getCollection, render } from 'astro:content';
import Entry from '../../layouts/Entry.astro';

export async function getStaticPaths() {
	const items = await getCollection('interviews');
	return items.map((item) => ({ params: { slug: item.id }, props: item }));
}

const item = Astro.props;
const { Content } = await render(item);
const meta = [item.data.medium, item.data.interviewer].filter(Boolean).join(' · ');
---

<Entry
	title={item.data.title}
	description={item.data.description ?? item.data.title}
	date={item.data.pubDate}
	meta={meta}
	eyebrow="Interview"
	image={item.data.ogImage}
	backHref="/interviews/"
	backLabel="All interviews"
>
	<Content />
	{item.data.url && (
		<p><a href={item.data.url} target="_blank" rel="noopener">→ Read the full interview</a></p>
	)}
</Entry>
